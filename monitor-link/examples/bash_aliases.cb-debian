# monitor-link client aliases (Debian Chromebook)
# Copy into: ~/.bash_aliases

alias cbc="$HOME/Tools/monitor-link/cb-connect.sh connect"
alias cbv="$HOME/Tools/monitor-link/cb-connect.sh connect"

# Safe fullscreen path (ssvnc); preferred over TigerVNC fullscreen
alias cbcf="$HOME/Tools/monitor-link/cb-connect.sh fullscreen"
alias cbcm="$HOME/Tools/monitor-link/cb-connect.sh mirror"
alias cbmf="$HOME/Tools/monitor-link/cb-connect.sh mirror-full"

# TigerVNC fullscreen legacy path (can gray-screen in mirror mode)
alias cbtf="$HOME/Tools/monitor-link/cb-connect.sh tigervnc-full"

alias cbcd="$HOME/Tools/monitor-link/cb-connect.sh disconnect"
alias cbcs="$HOME/Tools/monitor-link/cb-connect.sh status"
